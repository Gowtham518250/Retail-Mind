# ==========================================
# AI SHOP PRO - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your values
# For Render/Railway: Add these in Dashboard → Environment

# ==========================================
# 🗄️ DATABASE CONFIGURATION
# ==========================================
# For Render: This is provided automatically
# For Railway: Provided automatically
# For Local: Use PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_shop_pro

# ==========================================
# 🔴 REDIS CONFIGURATION  
# ==========================================
# For Caching & Session Management
# Format: redis://[:password@]host:port[/db]
# For local: redis://localhost:6379
# For Railway/Render: redis://default:password@redis-host:6379
REDIS_URL=redis://localhost:6379

# ==========================================
# 🔐 JWT & AUTHENTICATION
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-to-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# 📧 EMAIL CONFIGURATION
# ==========================================
# For Gmail: Use App Password (not regular password)
# Generate: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@aishoppro.com
EMAIL_FROM_NAME=AI Shop Pro

# Optional: Use SendGrid instead
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ==========================================
# 🌐 FRONTEND CONFIGURATION
# ==========================================
# URLs where frontend is hosted
FRONTEND_URL=https://your-domain.com
ALLOWED_HOSTS=your-domain.com,api.your-domain.com,www.your-domain.com

# For local development
# FRONTEND_URL=http://localhost:3000
# ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# 🔧 APPLICATION CONFIGURATION
# ==========================================
# Environment: production, staging, development
ENVIRONMENT=production

# Debug mode (NEVER True in production!)
DEBUG=False

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# 💳 PAYMENT GATEWAY (Optional)
# ==========================================
# For Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# For Stripe (alternative)
# STRIPE_API_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ==========================================
# 📱 SMS & OTP (Optional)
# ==========================================
# For Twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# For AWS SNS
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SNS_REGION=ap-south-1

# ==========================================
# ☁️ FILE STORAGE (Optional)
# ==========================================
# For AWS S3
AWS_S3_BUCKET=ai-shop-pro-bucket
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# For Google Cloud Storage
# GCS_BUCKET=ai-shop-pro-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# ==========================================
# 📊 ANALYTICS & MONITORING (Optional)
# ==========================================
# For Sentry (error tracking)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# For New Relic
# NEW_RELIC_LICENSE_KEY=xxxxx
# NEW_RELIC_APP_NAME=AI Shop Pro

# For Datadog
# DATADOG_API_KEY=xxxxx
# DATADOG_APP_KEY=xxxxx

# ==========================================
# 🔐 SECURITY (Production Only)
# ==========================================
# CORS trusted origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Rate limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=3600  # seconds

# Session timeout
SESSION_TIMEOUT_MINUTES=30

# ==========================================
# 📝 NOTES
# ==========================================
# 1. NEVER commit .env to Git (add to .gitignore)
# 2. Keep SECRET_KEY secret and unique per environment
# 3. Use strong, random passwords for all credentials
# 4. Rotate credentials regularly
# 5. For production, use service like AWS Secrets Manager
#
# Default values for local development:
# - DATABASE_URL: postgresql://postgres:password@localhost:5432/ai_shop_pro
# - REDIS_URL: redis://localhost:6379
# - DEBUG: False
# - ENVIRONMENT: production
#
# To generate SECRET_KEY:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# ==========================================
